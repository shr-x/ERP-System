model CustomerCreditReceipt {
  id              String        @id @default(uuid()) @db.Uuid
  orgId           String        @db.Uuid
  storeId         String        @db.Uuid
  receiptNo       String
  receiptDate     DateTime      @db.Timestamptz(6)
  customerId      String        @db.Uuid
  amountPaise     BigInt
  method          PaymentMethod
  upiRef          String?
  createdByUserId String        @db.Uuid
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)

  org        Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store      Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy  User                      @relation("CustomerCreditReceiptCreatedBy", fields: [createdByUserId], references: [id])
  shareLinks CustomerCreditShareLink[]
  printJobs  PrintJob[]

  @@unique([orgId, storeId, receiptNo])
  @@index([orgId, storeId, receiptDate(sort: Desc)])
  @@index([orgId, customerId, receiptDate(sort: Desc)])
}

model CustomerCreditUse {
