model Coupon {
  id              String             @id @default(uuid()) @db.Uuid
  orgId           String             @db.Uuid
  code            String
  title           String?
  amountPaise     BigInt
  usesTotal       Int
  usesRemaining   Int
  validFrom       DateTime           @default(now()) @db.Timestamptz(6)
  validTo         DateTime?          @db.Timestamptz(6)
  isActive        Boolean            @default(true)
  createdByUserId String             @db.Uuid
  createdAt       DateTime           @default(now()) @db.Timestamptz(6)
  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy       User               @relation(fields: [createdByUserId], references: [id])
  redemptions     CouponRedemption[]
  returns         SalesReturn[]

  @@unique([orgId, code])
  @@index([orgId, createdAt(sort: Desc)])
}

model CouponRedemption {
  id                 String       @id @default(uuid()) @db.Uuid
  orgId              String       @db.Uuid
  storeId            String       @db.Uuid
  couponId           String       @db.Uuid
  invoiceId          String       @db.Uuid
  redeemedByUserId   String       @db.Uuid
  amountAppliedPaise BigInt
  redeemedAt         DateTime     @default(now()) @db.Timestamptz(6)
  org                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store              Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupon             Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  invoice            SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  redeemedBy         User         @relation(fields: [redeemedByUserId], references: [id])

  @@unique([couponId, invoiceId])
  @@index([orgId, storeId, redeemedAt(sort: Desc)])
  @@index([orgId, couponId, redeemedAt(sort: Desc)])
}

model SalesReturn {
  id                String           @id @default(uuid()) @db.Uuid
  orgId             String           @db.Uuid
  storeId           String           @db.Uuid
  salesInvoiceId    String           @db.Uuid
  invoiceNo         String
  customerId        String           @db.Uuid
  processedByUserId String           @db.Uuid
  mode              ReturnCreditMode
  amountPaise       BigInt
  pointsCredited    Int              @default(0)
  couponId          String?          @db.Uuid
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)

  org         Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store       Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invoice     SalesInvoice           @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  processedBy User                   @relation(fields: [processedByUserId], references: [id])
  coupon      Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  lines       SalesReturnLine[]
  shareLinks  SalesReturnShareLink[]
  printJobs   PrintJob[]

  @@index([orgId, storeId, createdAt(sort: Desc)])
  @@index([orgId, invoiceNo])
}

model SalesReturnLine {
  id                 String           @id @default(uuid()) @db.Uuid
  orgId              String           @db.Uuid
  salesReturnId      String           @db.Uuid
  salesInvoiceLineId String           @db.Uuid
  productId          String           @db.Uuid
  productName        String
  hsnCode            String
  gstRateBp          Int
  qty                Decimal          @db.Decimal(14, 3)
  taxableValuePaise  BigInt
  cgstAmountPaise    BigInt
  sgstAmountPaise    BigInt
  igstAmountPaise    BigInt
  lineTotalPaise     BigInt
  salesReturn        SalesReturn      @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  invoiceLine        SalesInvoiceLine @relation(fields: [salesInvoiceLineId], references: [id], onDelete: Cascade)
  product            Product          @relation(fields: [productId], references: [id])
  org                Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([salesReturnId])
}

enum StitchingProductCategory {
  FULL_SET
  TOP
  PANTS
  SLEEVES
}

enum StitchingOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum StitchingMaterialSource {
  STORE
  CUSTOMER
}

model StitchingTemplateCategory {
  id         String                  @id @default(uuid()) @db.Uuid
  orgId      String                  @db.Uuid
  name       String
  posVisible Boolean                 @default(true)
  createdAt  DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime                @updatedAt @db.Timestamptz(6)
  templates  StitchingProductTemplate[]
  org        Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

model StitchingProductTemplate {
  id                  String                              @id @default(uuid()) @db.Uuid
  orgId               String                              @db.Uuid
  name                String
  category            StitchingProductCategory
  categoryId          String?                             @db.Uuid
  createdAt           DateTime                            @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                            @updatedAt @db.Timestamptz(6)
  measurementProfiles StitchingProductMeasurementProfile[]
  colors              StitchingProductColor[]
  materialConfigs     StitchingProductMaterialConfig[]
  orders              StitchingOrder[]
  categoryRef         StitchingTemplateCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  org                 Organization                        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, category])
  @@index([orgId, categoryId])
}

model StitchingProductMeasurementProfile {
  id              String                   @id @default(uuid()) @db.Uuid
  productId       String                   @db.Uuid
  measurementName String
  fields          String[]
  product         StitchingProductTemplate @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, measurementName])
  @@index([productId])
}

model StitchingProductColor {
  id        String                   @id @default(uuid()) @db.Uuid
  productId String                   @db.Uuid
  colorName String                   @default("")
  colorCode String                   @db.VarChar(7)
  imageUrl  String?
  imageData Bytes?
  imageMime String?
  product   StitchingProductTemplate @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, colorCode])
  @@index([productId])
}

model StitchingProductMaterialConfig {
  id            String                   @id @default(uuid()) @db.Uuid
  productId     String                   @db.Uuid
  erpMaterialId String                   @db.Uuid
  metersRequired Decimal                 @db.Decimal(14, 3)
  product       StitchingProductTemplate @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model StitchingCustomerProfile {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @db.Uuid
  erpCustomerId String           @db.Uuid
  notes         String?
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)
  orders        StitchingOrder[]
  org           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  erpCustomer   Customer         @relation(fields: [erpCustomerId], references: [id], onDelete: Cascade)

  @@unique([orgId, erpCustomerId])
  @@index([orgId, createdAt(sort: Desc)])
}

model StitchingTailor {
  id        String           @id @default(uuid()) @db.Uuid
  orgId     String           @db.Uuid
  name      String
  phone     String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @db.Timestamptz(6)
  orders    StitchingOrder[]
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, phone])
  @@index([orgId, isActive])
}

model StitchingOrder {
  id                    String                @id @default(uuid()) @db.Uuid
  orgId                 String                @db.Uuid
  storeId               String?               @db.Uuid
  orderCode             String
  erpInvoiceId          String?
  customerProfileId     String?               @db.Uuid
  productTemplateId     String                @db.Uuid
  materialSource        StitchingMaterialSource @default(STORE)
  selectedColorName     String?
  selectedColorCode     String
  selectedColorImageUrl String?
  measurementProfileName String?
  measurements          Json                  @default("{}")
  erpMaterialId         String?               @db.Uuid
  materialUsageMeters   Decimal?              @db.Decimal(14, 3)
  tailorId              String?               @db.Uuid
  deliveryDate          DateTime              @db.Timestamptz(6)
  pricePaise            BigInt
  gstRateBp             Int
  gstAmountPaise        BigInt
  tailorCostPaise       BigInt                @default(0)
  gstOnTailor           Boolean               @default(false)
  tailorGstRateBp       Int                   @default(0)
  tailorExpenseJournalEntryId String?
  tailorExpensePostedAt DateTime?             @db.Timestamptz(6)
  status                StitchingOrderStatus  @default(PENDING)
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)

  org             Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  store           Store?                   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customerProfile StitchingCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  productTemplate StitchingProductTemplate @relation(fields: [productTemplateId], references: [id], onDelete: Restrict)
  tailor          StitchingTailor?        @relation(fields: [tailorId], references: [id], onDelete: SetNull)

  @@unique([orgId, orderCode])
  @@index([orgId, status, deliveryDate(sort: Desc)])
  @@index([orgId, orderCode])
  @@index([orgId, customerProfileId])
  @@index([orgId, tailorId])
  @@index([orgId, storeId])
}

model StitchingTailorSlipShareLink {
  id        String       @id @default(uuid()) @db.Uuid
  orgId     String       @db.Uuid
  orderId   String       @db.Uuid
  token     String       @unique
  expiresAt DateTime?    @db.Timestamptz(6)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orderId])
}
